{
  "name": "philharmony/http-enum",
  "description": "Type-safe HTTP enums for methods, status codes, headers, content types, schemes, caching and protocol utilities",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "http",
    "enum",
    "http-method",
    "status-code",
    "http-header",
    "content-type",
    "cache-control",
    "content-encoding",
    "samesite",
    "psr",
    "php"
  ],
  "homepage": "https://github.com/philharmonytech/http-enum",
  "authors": [
    {
      "name": "Vyacheslav86RUS",
      "email": "ProSlavon86@gmail.com",
      "role": "Lead Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/philharmonytech/http-enum/issues",
    "source": "https://github.com/philharmonytech/http-enum"
  },
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Philharmony\\Http\\Enum\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Philharmony\\Http\\Enum\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-clover coverage.xml --coverage-html coverage --coverage-filter src",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "cs-check": "php-cs-fixer fix --dry-run --allow-risky=yes",
    "cs-fix": "php-cs-fixer fix --allow-risky=yes"
  },
  "config": {
    "sort-packages": true
  }
}